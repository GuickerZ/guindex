  "formatter": {
    "id": "custom",
    "definition": {
      "name": "{stream.proxied::istrue[\"☁ \"||\"\"]}\n{stream.type::=live[\" [LIVE 🔴]\"||\"\"]}\n{stream.type::=p2p[\" [P2P ⚠️]\"||\"\"]}\n{stream.type::=usenet[\" [USENET 📰]\"||\"\"]}\n{stream.type::=Http[\" [WEB 🌐]\"||\"\"]}\n{stream.type::=External[\" [EXTLINK 🔗]\"||\"\"]}\n{service.shortName::exists[\"[{service.shortName}\"||\"\"]}{service.cached::istrue[\"⚡] \"||\"\"]}{service.cached::isfalse[\"⏳] \"||\"\"]}{addon.name} {stream.resolution::=2160p[\"[✨4K]\"||\"\"]}{stream.resolution::=1440p[\"[📀 1440p]\"||\"\"]}{stream.resolution::=1080p[\"[🚀 1080p]\"||\"\"]}{stream.resolution::=720p[\"[💿 720p]\"||\"\"]}\n\n\n",
      "description": "🎬 {stream.title::exists[\"{stream.title}\"||\"\"]}{stream.year::exists[\" ({stream.year})\"||\"\"]} {stream.quality::exists[\"[{stream.quality}]\"||\"\"]}{stream.library::istrue[\" · 📂\"||\"\"]} {stream.filename::~Extended[\"[Extended Cut] \"||\"\"]}{stream.filename::~Theatrical[\"[Theatrical Cut] \"||\"\"]}{stream.filename::~Director[\"[Director's Cut] \"||\"\"]}{stream.filename::~DC[\"[Director's Cut] \"||\"\"]}{stream.filename::~Ultimate[\"[Ultimate Edition] \"||\"\"]}{stream.filename::~Special[\"[Special Edition] \"||\"\"]}{stream.filename::~Alternate[\"[Alternate Edition] \"||\"\"]}{stream.filename::~Redux[\"[Redux] \"||\"\"]}\n\\n{stream.season::>=0[\"S\"||\"\"]}{stream.season::<=9[\"0\"||\"\"]}{stream.season::>0[\"{stream.season}\"||\"\"]}{stream.episode::>=0[\"  ·  E\"||\"\"]}{stream.episode::<=9[\"0\"||\"\"]}{stream.episode::>0[\"{stream.episode}\"||\"\"]}\n\\n ‎ \n\\n{stream.encode::exists[\"📟  {stream.encode} \"||\"\"]}{stream.visualTags::exists[\"🔆 {stream.visualTags::join(' · ')} \"||\"\"]}\n\\n{stream.audioTags::exists[\"🎵  {stream.audioTags::join(' · ')} \"||\"\"]}{stream.audioChannels::exists[\"🎧  {stream.audioChannels::join(' · ')}\"||\"\"]}\n\\n{stream.size::>0[\"📦  {stream.size::bytes} \"||\"\"]}{stream.folderSize::>0[\"/ {stream.folderSize::bytes}\"||\"\"]}{stream.seeders::>0[\" ⇋ {stream.seeders} 🌱 \"||\"\"]}{stream.duration::>0[\" · ⏱️ {stream.duration::time} \"||\"\"]}{stream.age::exists[\" · 📆 {stream.age} \"||\"\"]}\n\\n{stream.proxied::istrue[\"🔒  \"||\"\"]}{stream.releaseGroup::exists[\"🏷️ {stream.releaseGroup}  · \"||\"\"]}{stream.indexer::exists[\"📡 {stream.indexer}\"||\"\"]}\n\\n{stream.languages::exists[\"🗣️ {stream.languageEmojis::join(' / ')::replace('🇵🇹', '🇧🇷')::replace('PT', 'PT-BR')}\"||\"\"]}\n{stream.folderName::exists[\"📁  {stream.folderName}\"||\"\"]}\n{stream.filename::exists[\"📄  {stream.filename}\"||\"\"]}\n\\n{stream.message::exists[\"ℹ️  {stream.message}\"||\"\"]}"
    }
