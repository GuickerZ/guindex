# ──────────────────────────────────────────────────────────
# GuIndex - Variaveis de Ambiente
# Copie este arquivo para .env e preencha seus dados.
# ──────────────────────────────────────────────────────────

# Porta do servidor (padrao: 7000)
PORT=7000

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# ── URL PUBLICA (OBRIGATORIO em producao) ──
# Defina com o dominio publico da sua instancia.
# Em dev local, deixe comentado (usa http://localhost:PORT automaticamente).
# BASE_URL=https://guindex-stremio.vercel.app

# ── Torrent Indexer ──
# URL do torrent-indexer (padrao: https://torrent-indexer-latest.onrender.com)
# Para self-host: https://github.com/felipemarinho97/torrent-indexer
# Docker: docker run -p 8080:8080 ghcr.io/felipemarinho97/torrent-indexer:latest
# TORRENT_INDEXER_URL=https://torrent-indexer-latest.onrender.com

# ── TorBox (avancado) ──
# TORBOX_WAIT_VIDEO_URL=https://aiostreams.elfhosted.com/static/downloading.mp4
# TORBOX_STREAM_LIMIT=15
