# ──────────────────────────────────────────────────────────
# GuIndex — Variáveis de Ambiente
# Copie este arquivo para .env e preencha seus dados.
# ──────────────────────────────────────────────────────────

# Porta do servidor
PORT=7000

# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# URL pública da sua instância (OBRIGATÓRIO em produção)
# Em desenvolvimento local, deixe comentado (usa http://localhost:PORT)
# BASE_URL=https://seu-dominio.com

# ── Debrid (opcional — pode ser passado via query string) ──
# REALDEBRID_TOKEN=seu_token_aqui
# TORBOX_TOKEN=seu_token_aqui

# ── Torrent Indexer ──
# URL do torrent-indexer. Padrão: https://torrent-indexer.darklyn.org
# Recomendamos self-host: https://github.com/felipemarinho97/torrent-indexer
# TORRENT_INDEXER_URL=http://localhost:8080

# ── TorBox (avançado) ──
# TORBOX_WAIT_VIDEO_URL=https://aiostreams.elfhosted.com/static/downloading.mp4
# TORBOX_STREAM_LIMIT=15
