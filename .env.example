# ──────────────────────────────────────────────────────────
# GuIndex - Variaveis de Ambiente
# Copie este arquivo para .env e preencha seus dados.
# ──────────────────────────────────────────────────────────

# Porta do servidor (padrao: 7000)
PORT=7000

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# ── URL PUBLICA (OBRIGATORIO em producao) ──
# Defina com o dominio publico da sua instancia.
# Em dev local, deixe comentado (usa http://localhost:PORT automaticamente).
# BASE_URL=https://guindex-stremio.vercel.app

# ── Torrent Indexer ──
# URL do torrent-indexer (padrao: http://guindex.duckdns.org:8090)
# Para self-host: https://github.com/felipemarinho97/torrent-indexer
# Docker: docker run -p 8090:7006 ghcr.io/felipemarinho97/torrent-indexer:latest
# TORRENT_INDEXER_URL=http://guindex.duckdns.org:8090
# TORRENT_INDEXER_ENABLE_FALLBACK=true
# TORRENT_INDEXER_FALLBACK_CONCURRENCY=3
# TORRENT_INDEXER_MAX_QUERY_TIME_MS=15000
# TORRENT_INDEXER_TARGET_STREAMS=12
# TORRENT_INDEXER_MAX_DYNAMIC_QUERIES=10
# TORRENT_INDEXER_DISABLED_INDEXERS=comando_torrents
# TORRENT_INDEXER_FAILURE_THRESHOLD=2
# TORRENT_INDEXER_FAILURE_COOLDOWN_MS=900000

# ── TorBox (avancado) ──
# TORBOX_WAIT_VIDEO_URL=https://aiostreams.elfhosted.com/static/downloading.mp4
# TORBOX_STREAM_LIMIT=15
